NODE_ENV=production
LOG_LEVEL=info

# Public URLs
APP_BASE_URL=https://foodtruckzs.com
API_BASE_URL=https://foodtruckzs.com
NEXT_PUBLIC_APP_BASE_URL=https://foodtruckzs.com
NEXT_PUBLIC_API_BASE_URL=https://foodtruckzs.com
CORS_ORIGINS=https://foodtruckzs.com,https://www.foodtruckzs.com

# Local process bindings behind Apache2
WEB_HOST=127.0.0.1
WEB_PORT=3000
API_HOST=127.0.0.1
API_PORT=4000
REQUEST_BODY_LIMIT_BYTES=33554432

# PostgreSQL
DATABASE_URL=postgres://foodtruckzs_app:replace-me@127.0.0.1:5432/foodtruckzs
DATABASE_MAX_CONNECTIONS=10

# Authentication secrets
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_SECRET=replace-with-another-32-random-characters
REFRESH_TOKEN_TTL_DAYS=30

# Endpoint rate limits
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_RFQ_SUBMISSION_MAX=10
RATE_LIMIT_RFQ_SUBMISSION_WINDOW_MS=600000
RATE_LIMIT_MESSAGING_MAX=60
RATE_LIMIT_MESSAGING_WINDOW_MS=60000
RATE_LIMIT_PAYMENT_CREATION_MAX=10
RATE_LIMIT_PAYMENT_CREATION_WINDOW_MS=600000

# Stripe
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CONNECT_CLIENT_ID=ca_replace_me

# Email provider
EMAIL_PROVIDER_API_KEY=replace-me
EMAIL_FROM_ADDRESS=no-reply@foodtruckzs.com
SUPPORT_EMAIL=support@foodtruckzs.com

# File/object storage
FILE_STORAGE_PROVIDER=s3
FILE_STORAGE_BUCKET=foodtruckzs-production
FILE_STORAGE_SIGNED_URL_TTL_SECONDS=900
FILE_STORAGE_SIGNING_SECRET=replace-with-at-least-32-random-characters
OBJECT_STORAGE_ENDPOINT=https://replace-me.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me

# Worker tuning
NOTIFICATION_WORKER_POLL_INTERVAL_MS=5000
NOTIFICATION_WORKER_BATCH_SIZE=25

# Operational scripts
BACKUP_DIR=/var/backups/foodtruckzs/postgres
BACKUP_RETENTION_DAYS=30
PUBLIC_BASE_URL=https://foodtruckzs.com
