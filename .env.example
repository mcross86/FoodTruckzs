NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# API
API_HOST=0.0.0.0
API_PORT=4000
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
REQUEST_BODY_LIMIT_BYTES=33554432
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_RFQ_SUBMISSION_MAX=10
RATE_LIMIT_RFQ_SUBMISSION_WINDOW_MS=600000
RATE_LIMIT_MESSAGING_MAX=60
RATE_LIMIT_MESSAGING_WINDOW_MS=60000
RATE_LIMIT_PAYMENT_CREATION_MAX=10
RATE_LIMIT_PAYMENT_CREATION_WINDOW_MS=600000
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
# Access token lifetime in seconds. Development allows up to 604800 (7 days); production max 3600.
# 28800 = 8 hours (comfortable local testing). 900 = 15 minutes (production-style).
JWT_ACCESS_TOKEN_TTL_SECONDS=28800
REFRESH_TOKEN_SECRET=replace-with-another-32-random-characters
REFRESH_TOKEN_TTL_DAYS=30

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/foodtruckzs
DATABASE_MAX_CONNECTIONS=5
# Optional: used by integration tests that apply migrations and assert database constraints.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/foodtruckzs_test

# File storage
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_LOCAL_ROOT=.local-storage
FILE_STORAGE_BUCKET=foodtruckzs-dev
FILE_STORAGE_SIGNED_URL_TTL_SECONDS=900
FILE_STORAGE_SIGNING_SECRET=replace-with-at-least-32-random-characters

# Integrations will be wired in later phases.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
EMAIL_PROVIDER_API_KEY=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
